    def _on_tree_mousewheel(self, event, tree):
        try:
            tree.yview_scroll(int(-1 * (event.delta / 120)), "units")
        except Exception:
            pass
        return "break"

    def _on_text_mousewheel(self, event, widget):
        try:
            widget.yview_scroll(int(-1 * (event.delta / 120)), "units")
        except Exception:
            pass
