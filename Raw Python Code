        elif rc == 0:
            self.queue.put("PROGRESS:System Repair:DISM repair completed successfully")
        else:
            self.queue.put(f"PROGRESS:System Repair:DISM completed with return code: {rc}")

        # Step 3: Run SFC again after DISM
